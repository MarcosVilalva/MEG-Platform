generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  BLOCKED
}

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  passwordHash   String     @default("")
  role           UserRole   @default(VIEWER)
  status         UserStatus @default(ACTIVE)
  isActive       Boolean    @default(true)
  approvedAt     DateTime?
  approvedById   String?
  rejectedAt     DateTime?
  rejectionNote  String?
  lastLoginAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  events         FinancialEvent[]
  sessions       AuthSession[]
  auditLogs      AuditLog[]
  customers      Customer[]
  receivables    Receivable[]
  importBatches  ImportBatch[]
  budgets        Budget[]
  creditCards    CreditCard[]
  cardPurchases  CardPurchase[]

  @@index([status])
  @@index([role])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id             String   @id @default(cuid())
  name           String
  type           String
  institution    String?
  openingBalance Decimal  @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events         FinancialEvent[]
  ledgerEntries  LedgerEntry[]
  receipts       Receipt[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  group     String?
  type      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    FinancialEvent[]
  cardPurchases CardPurchase[]
}

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    FinancialEvent[]
  receipts  Receipt[]
}

model FinancialEvent {
  id              String   @id @default(cuid())
  userId          String?
  description     String
  type            String
  status          String   @default("planned")
  date            DateTime
  competence      String
  amount          Decimal
  signedAmount    Decimal
  notes           String?
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User?          @relation(fields: [userId], references: [id])
  accountId        String?
  account          Account?       @relation(fields: [accountId], references: [id])
  categoryId       String?
  category         Category?      @relation(fields: [categoryId], references: [id])
  paymentMethodId  String?
  paymentMethod    PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  ledgerEntries    LedgerEntry[]
  receipt          Receipt?
  importedRow      ImportedRow?
}

model LedgerEntry {
  id        String   @id @default(cuid())
  eventId   String
  date      DateTime
  accountId String
  debit     Decimal  @default(0)
  credit    Decimal  @default(0)
  memo      String?
  createdAt DateTime @default(now())

  event     FinancialEvent @relation(fields: [eventId], references: [id])
  account   Account        @relation(fields: [accountId], references: [id])
}

model Customer {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  document  String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  receivables Receivable[]

  @@index([userId, name])
}

model Receivable {
  id             String   @id @default(cuid())
  userId         String
  customerId     String?
  description    String
  totalAmount    Decimal
  openAmount     Decimal
  dueDate        DateTime
  status         String   @default("open")
  installmentNo  Int      @default(1)
  installmentQty Int      @default(1)
  interestRate   Decimal  @default(0)
  fineRate       Decimal  @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  receipts   Receipt[]

  @@index([userId, dueDate])
  @@index([status])
}

model Receipt {
  id              String   @id @default(cuid())
  receivableId    String
  amount          Decimal
  receivedAt      DateTime
  interestAmount  Decimal  @default(0)
  fineAmount      Decimal  @default(0)
  accountId       String?
  paymentMethodId String?
  financialEventId String? @unique
  notes           String?
  createdAt       DateTime @default(now())

  receivable    Receivable     @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  account       Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  financialEvent FinancialEvent? @relation(fields: [financialEventId], references: [id], onDelete: SetNull)

  @@index([receivableId, receivedAt])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String?
  month     String
  group     String
  amount    Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, group])
  @@index([userId, month])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  entity    String
  entityId  String
  action    String
  metadata  String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
}
model ImportBatch {
  id            String   @id @default(cuid())
  userId        String
  fileName      String
  fileHash      String
  sourceEncoding String  @default("cp850")
  rowCount      Int
  importedCount Int      @default(0)
  issueCount    Int      @default(0)
  status        String   @default("processing")
  createdAt     DateTime @default(now())
  completedAt   DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows          ImportedRow[]

  @@unique([userId, fileHash])
  @@index([userId, createdAt])
}

model ImportedRow {
  id             String   @id @default(cuid())
  batchId        String
  rowNumber      Int
  eventId        String?  @unique
  status         String
  issueCode      String?
  duplicateOfRow Int?
  rawData        Json
  createdAt      DateTime @default(now())

  batch          ImportBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  event          FinancialEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([batchId, rowNumber])
  @@index([batchId, status])
}

model CreditCard {
  id          String   @id @default(cuid())
  userId      String
  name        String
  issuer      String?
  brand       String?
  lastFour    String?
  creditLimit Decimal
  closingDay  Int
  dueDay      Int
  color       String?  @default("#0f766e")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases   CardPurchase[]

  @@index([userId, isActive])
}

model CardPurchase {
  id           String   @id @default(cuid())
  userId       String
  cardId       String
  categoryId   String?
  description  String
  totalAmount  Decimal
  purchaseDate DateTime
  installments Int      @default(1)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  category     Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entries      CardInstallment[]

  @@index([userId, purchaseDate])
  @@index([cardId, status])
}

model CardInstallment {
  id          String   @id @default(cuid())
  purchaseId  String
  number      Int
  amount      Decimal
  statementMonth String
  status      String   @default("open")
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  purchase    CardPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@unique([purchaseId, number])
  @@index([statementMonth, status])
}
