{
  "name": "meg-financial-os",
  "version": "1.3.0-project-phoenix",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/core",
    "packages/ui",
    "packages/shared",
    "packages/analytics",
    "packages/intelligence",
    "apps/api",
    "packages/database"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "build": "npm-run-all build:web build:api",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api run build",
    "check": "npm-run-all test build",
    "test": "npm-run-all test:core test:imports test:notifications test:auth test:cors test:legacy-finance",
    "test:core": "node packages/core/src/tests/core.test.js",
    "test:imports": "npm --workspace apps/api run test:imports",
    "test:notifications": "npm --workspace apps/api run test:notifications",
    "test:auth": "npm --workspace apps/api run test:auth",
    "test:cors": "npm --workspace apps/api run test:cors",
    "test:legacy-finance": "node apps/web/src/legacy-finance.test.js",
    "lint": "echo \"Lint configurado para próxima sprint\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "start:api": "npm --workspace apps/api run start",
    "db:generate": "npm --workspace packages/database run db:generate",
    "db:push": "npm --workspace packages/database run db:push",
    "db:push:production": "npm --workspace packages/database run db:push:production",
    "db:prepare:production": "npm --workspace packages/database run db:prepare:production",
    "db:seed": "npm --workspace packages/database run db:seed",
    "db:studio": "npm --workspace packages/database run db:studio",
    "db:generate:legacy": "npm --workspace packages/database run db:generate:legacy",
    "db:migrate:supabase": "npm --workspace packages/database run db:migrate:supabase",
    "db:import:basemeg": "npm --workspace packages/database run db:import:basemeg --",
    "phoenix:setup": "npm install && npm run db:generate && npm run db:push && npm run db:seed",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/status-bar": "^7.0.6",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "npm-run-all": "^4.1.5"
  }
}
