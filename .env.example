# Shared database configuration
# PostgreSQL do Supabase (use a conexão pelo Session Pooler)
DATABASE_URL="postgresql://postgres.PROJECT_REF:SENHA@HOST_POOLER:5432/postgres?sslmode=require"

# Usado somente uma vez para importar o banco SQLite antigo
LEGACY_DATABASE_URL="file:./prisma/dev.db"

# API runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3333
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,https://marcosvilalva.github.io

# Frontend runtime (Vite variables must start with VITE_)
VITE_API_URL=https://meg-platform-api.onrender.com

# E-mail transacional (Resend)
# onboarding@resend.dev serve somente para testar o e-mail proprietário da conta.
# Para enviar a todos os usuários, verifique um domínio no Resend e use, por exemplo:
# NOTIFICATION_EMAIL_FROM="MEG Finanças <acesso@seudominio.com>"
RESEND_API_KEY=""
NOTIFICATION_EMAIL_FROM="MEG Finanças <onboarding@resend.dev>"

# WhatsApp (Evolution API), usado também como alternativa segura na recuperação de senha
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="meg-financas"
